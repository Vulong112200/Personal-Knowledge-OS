# Copy the relevant sections into apps/api/.env and apps/web/.env.local
# See plan: C:\Users\vuhp\.claude\plans\project-personal-knowledge-mellow-dove.md

# --- apps/api/.env ---

# Supabase Postgres (M0b)
# Use the DIRECT connection string (port 5432), NOT the pooled one (port 6543).
# Prisma ORM v7 removed the old directUrl (pooled+direct split) config option —
# prisma.config.ts now takes a single datasource.url, used for both the running
# app and migrations. Fine at this project's scale.
DATABASE_URL=

# Supabase Auth (M1)
SUPABASE_URL=
SUPABASE_JWT_SECRET=     # or JWKS URL, depending on Supabase project signing config
SUPABASE_SERVICE_ROLE_KEY=

# Redis / BullMQ (M3)
REDIS_URL=               # rediss://... from Upstash

# Storage (M2)
STORAGE_DRIVER=local
STORAGE_ROOT=./var/storage

# AI (M5) — app must boot fine with these unset/false. Chat-only (via OpenRouter, OpenAI-
# compatible API) — OpenRouter has no embeddings endpoint, so semantic search is out of
# scope; search stays full-text only (M4).
AI_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional AI-call bounds (app-level). Defaults: 60000ms timeout, 1024 max output tokens.
OPENROUTER_TIMEOUT_MS=60000
OPENROUTER_MAX_TOKENS=1024

# Comma-separated list of allowed web origins for CORS. Leave unset in local dev to allow
# all origins. In production (NODE_ENV=production) an empty list is FAIL-CLOSED (no cross-origin
# browser requests) — you MUST set it to your web origin(s), e.g. https://app.example.com.
CORS_ORIGINS=

# OCR for scanned PDFs (tesseract.js). On by default; set OCR_ENABLED=false to disable.
# Traineddata is fetched on first use. OCR_LANGS is a '+'-joined Tesseract lang list.
# OCR_CONCURRENCY caps simultaneous OCR runs regardless of worker job concurrency (memory guard).
OCR_ENABLED=true
OCR_LANGS=eng+vie
OCR_CONCURRENCY=1

# How many days succeeded processing_jobs rows are kept before the daily cleanup cron prunes
# them (failed rows are retained). Default 7.
PROCESSING_JOBS_RETENTION_DAYS=7

# Local embeddings (transformers.js) for semantic + hybrid RAG. Opt-in — CPU-heavy and
# downloads model weights (~100MB) on first use. Chat retrieval fuses lexical + semantic
# (RRF) when enabled, lexical-only when off. Changing the model/dimensions needs a matching
# migration on the embeddings.embedding vector(N) column (default 384 = multilingual-e5-small).
EMBEDDINGS_ENABLED=false
EMBEDDING_MODEL=Xenova/multilingual-e5-small
EMBEDDING_DIMENSIONS=384

PORT=3001

# --- apps/web/.env.local ---

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
