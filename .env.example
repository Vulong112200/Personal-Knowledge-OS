# Copy the relevant sections into apps/api/.env and apps/web/.env.local
# See plan: C:\Users\vuhp\.claude\plans\project-personal-knowledge-mellow-dove.md

# --- apps/api/.env ---

# Supabase Postgres (M0b)
DATABASE_URL=            # pooled connection, port 6543 — used at runtime
DIRECT_URL=              # non-pooled connection, port 5432 — used for Prisma migrations

# Supabase Auth (M1)
SUPABASE_URL=
SUPABASE_JWT_SECRET=     # or JWKS URL, depending on Supabase project signing config
SUPABASE_SERVICE_ROLE_KEY=

# Redis / BullMQ (M3)
REDIS_URL=               # rediss://... from Upstash

# Storage (M2)
STORAGE_DRIVER=local
STORAGE_ROOT=./var/storage

# AI (M5) — app must boot fine with these unset/false
AI_ENABLED=false
OPENAI_API_KEY=

PORT=3001

# --- apps/web/.env.local ---

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
