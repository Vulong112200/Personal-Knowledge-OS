# Uploaded object storage — ignore contents at any depth (e.g. apps/api/var/storage/),
# but keep the .gitkeep dir marker. Ignore contents (*) not the dir, so the negation works.
**/var/storage/*
!**/var/storage/.gitkeep

*.log
